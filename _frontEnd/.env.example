# Mitrufely Web — Variables de entorno del Frontend (PLANTILLA)
#
# Copia este archivo a .env.local para desarrollo local:
#   cp .env.example .env.local
#
# NUNCA commitees .env.local con valores reales.
# Los valores VITE_* se inlinean en el bundle en build time.

# ─── API ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ─── Aplicación ─────────────────────────────────────
VITE_APP_NAME=Mitrufely
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ─── Auth / JWT ─────────────────────────────────────
# El access token se almacena SOLO en memoria (no en localStorage/sessionStorage)
# El refresh token se gestiona en memoria (futuro: cookie httpOnly del backend)
VITE_JWT_EXPIRES_IN=15m
VITE_REFRESH_EXPIRES_IN=7d

# ─── Feature Flags ──────────────────────────────────
VITE_ENABLE_SWEETCOINS=true
VITE_ENABLE_FEFO_ALERTS=true
VITE_ENABLE_PDF_EXPORT=true

# ─── Sentry (opcional) ──────────────────────────────
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ─── Analytics (opcional) ───────────────────────────
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Google OAuth ───────────────────────────────────
# Obtener en: https://console.cloud.google.com/ → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
